<%- include('partials/header') %>
<section class="page-hero compact"><div class="container"><div><span class="kicker"><%= user.role %> space</span><h1>Good <%= new Date().getHours() < 12 ? 'morning' : new Date().getHours() < 18 ? 'afternoon' : 'evening' %>, <%= user.name.split(' ')[0] %>.</h1><p><%= user.role === 'Donor' ? 'Manage your donations and see where your surplus food goes.' : 'Your collections turn spare food into shared meals.' %></p></div><% if (user.role === 'Donor' && user.is_verified) { %><a class="button" href="/donations/new"><i class="fa-solid fa-plus"></i> New donation</a><% } else if (user.role === 'Volunteer') { %><a class="button" href="/donations">Find food to collect</a><% } %></div></section>
<section class="section container dashboard-section">
  <% if (user.role === 'Donor' && !user.is_verified) { %><div class="notice warning"><i class="fa-solid fa-hourglass-half"></i><div><strong>Verification pending</strong><p>An administrator is reviewing your donor account. You can publish listings once approved.</p></div></div><% } %>
  <div class="widget-grid"><div class="widget"><span class="widget-icon green"><i class="fa-solid fa-box-open"></i></span><div><small><%= user.role === 'Donor' ? 'Total donations' : 'Collections joined' %></small><strong><%= summary.total %></strong></div></div><div class="widget"><span class="widget-icon amber"><i class="fa-solid fa-bolt"></i></span><div><small>Active now</small><strong><%= summary.active %></strong></div></div><div class="widget"><span class="widget-icon coral"><i class="fa-solid fa-utensils"></i></span><div><small>Estimated meals</small><strong><%= summary.meals %></strong></div></div><div class="widget"><span class="widget-icon blue"><i class="fa-solid fa-circle-check"></i></span><div><small>Completed</small><strong><%= summary.completed %></strong></div></div></div>
  <div class="panel"><div class="panel-heading"><div><h2><%= user.role === 'Donor' ? 'Donation history' : 'Collection history' %></h2><p>All your activity, newest first.</p></div></div>
    <% const records = user.role === 'Donor' ? listings : claims; %>
    <% if (records.length) { %><div class="table-wrap"><table><thead><tr><th>Food</th><th>Status</th><th>Quantity</th><th>Expiry</th><th><%= user.role === 'Donor' ? 'Volunteer' : 'Donor' %></th><th><span class="sr-only">Actions</span></th></tr></thead><tbody><% records.forEach(item => { %><tr><td><a class="table-food" href="/donations/<%= item.listing_id %>"><% if(item.image_url){ %><img src="<%= item.image_url %>" alt=""><% } else { %><span><i class="fa-solid fa-bowl-food"></i></span><% } %><div><strong><%= item.food_name %></strong><small><%= item.food_category %></small></div></a></td><td><span class="status-badge status-<%= item.status.toLowerCase() %>"><%= item.status %></span></td><td><%= item.quantity %></td><td><%= formatDate(item.expiry_date) %></td><td><%= user.role === 'Donor' ? (item.volunteer_name || 'Not claimed') : item.donor_name %></td><td><div class="table-actions"><a class="icon-button" href="<%= user.role === 'Volunteer' ? `/volunteer/claims/${item.listing_id}` : `/donations/${item.listing_id}` %>" aria-label="View"><i class="fa-regular fa-eye"></i></a><% if(user.role === 'Donor' && item.status === 'Available'){ %><a class="icon-button" href="/donations/<%= item.listing_id %>/edit" aria-label="Edit"><i class="fa-regular fa-pen-to-square"></i></a><form action="/donations/<%= item.listing_id %>?_method=DELETE" method="post" data-confirm="Delete this donation? This cannot be undone."><button class="icon-button danger" aria-label="Delete"><i class="fa-regular fa-trash-can"></i></button></form><% } %><% if(user.role === 'Donor' && ['Collected','Delivered'].includes(item.status)){ %><form action="/donations/<%= item.listing_id %>/complete" method="post"><button class="button button-tiny">Confirm handover</button></form><% } %></div></td></tr><% }) %></tbody></table></div><% } else { %><div class="empty-state small"><i class="fa-solid fa-basket-shopping"></i><h3>No activity yet</h3><p><%= user.role === 'Donor' ? 'Share your first surplus food listing.' : 'Browse available donations and accept a collection.' %></p><a class="button" href="<%= user.role === 'Donor' ? '/donations/new' : '/donations' %>">Get started</a></div><% } %>
  </div>
</section>
<%- include('partials/footer') %>
