<%- include('../partials/header') %>
<section class="auth-section"><div class="auth-shell"><div class="auth-side"><span class="kicker light">Welcome back</span><h1>Small actions.<br>Real impact.</h1><p>Sign in to manage donations, collect food, and see the difference you are making.</p><div class="auth-quote"><i class="fa-solid fa-quote-left"></i><p>When food is shared, communities grow stronger.</p></div></div><div class="auth-card"><h2>Log in</h2><p>Continue your food rescue journey.</p><form method="post" action="/login" class="stack-form"><input type="hidden" name="next" value="<%= next %>"><label>Email address<input type="email" name="email" autocomplete="email" placeholder="you@example.com" required></label><label>Password<div class="password-wrap"><input type="password" name="password" autocomplete="current-password" placeholder="Enter your password" required><button type="button" class="password-toggle" aria-label="Show password"><i class="fa-regular fa-eye"></i></button></div></label><button class="button full" type="submit">Log in <i class="fa-solid fa-arrow-right"></i></button></form><p class="auth-switch">New here? <a href="/register">Create an account</a></p></div></div></section>
