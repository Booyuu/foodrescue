<%- include('../partials/header') %>
<section class="auth-section"><div class="auth-shell wide"><div class="auth-side"><span class="kicker light">Join the movement</span><h1>Turn surplus<br>into support.</h1><p>Whether you share food or move it, your time makes a measurable difference.</p><ul class="feature-list"><li><i class="fa-solid fa-check"></i> Simple, secure donation tracking</li><li><i class="fa-solid fa-check"></i> Real-time collection updates</li><li><i class="fa-solid fa-check"></i> Personal rescue impact</li></ul></div><div class="auth-card"><h2>Create your account</h2><p>Choose how you would like to help.</p><% if (typeof inlineErrors !== 'undefined') { %><div class="inline-errors"><% inlineErrors.forEach(error => { %><p><i class="fa-solid fa-circle-exclamation"></i> <%= error %></p><% }) %></div><% } %><form method="post" action="/register" class="stack-form"><fieldset class="role-picker"><legend>I want to</legend><label><input type="radio" name="role" value="Donor" <%= formData.role !== 'Volunteer' ? 'checked' : '' %>><span><i class="fa-solid fa-store"></i><strong>Donate food</strong><small>Share safe surplus food</small></span></label><label><input type="radio" name="role" value="Volunteer" <%= formData.role === 'Volunteer' ? 'checked' : '' %>><span><i class="fa-solid fa-person-biking"></i><strong>Volunteer</strong><small>Collect and deliver food</small></span></label></fieldset><div class="form-grid"><label>Full name<input name="name" value="<%= formData.name || '' %>" autocomplete="name" required></label><label>Mobile number<input name="mobile_number" value="<%= formData.mobile_number || '' %>" autocomplete="tel" placeholder="9123 4567" required></label></div><label>Email address<input type="email" name="email" value="<%= formData.email || '' %>" autocomplete="email" required></label><div class="form-grid"><label>Password<input type="password" name="password" minlength="8" autocomplete="new-password" required></label><label>Confirm password<input type="password" name="confirm_password" minlength="8" autocomplete="new-password" required></label></div><small class="help-text">Use at least 8 characters.</small><button class="button full" type="submit">Create account <i class="fa-solid fa-arrow-right"></i></button></form><p class="auth-switch">Already have an account? <a href="/login">Log in</a></p></div></div></section>
<%- include('../partials/footer') %>
