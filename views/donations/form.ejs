<%- include('../partials/header') %>
<section class="page-hero compact"><div class="container"><div><span class="kicker">Donor listing</span><h1><%= title %></h1><p>Clear details help volunteers collect safely and on time.</p></div></div></section>
<section class="section container form-page"><form class="panel donation-form" method="post" action="<%= action %>" enctype="multipart/form-data"><% if(typeof inlineErrors !== 'undefined'){ %><div class="inline-errors"><% inlineErrors.forEach(error => { %><p><i class="fa-solid fa-circle-exclamation"></i> <%= error %></p><% }) %></div><% } %><div class="form-section"><div class="form-section-title"><span>01</span><div><h2>What are you sharing?</h2><p>Give volunteers enough detail to plan the rescue.</p></div></div><div class="form-grid"><label>Food name<input name="food_name" value="<%= listing.food_name || '' %>" maxlength="120" placeholder="e.g. Vegetable curry" required></label><label>Category<select name="food_category" required><option value="">Select category</option><% ['Bakery','Cooked Food','Fruit & Vegetables','Dairy','Packaged Food','Other'].forEach(category => { %><option <%= listing.food_category === category ? 'selected' : '' %>><%= category %></option><% }) %></select></label></div><label>Description<textarea name="description" rows="4" maxlength="1000" placeholder="Ingredients, allergens, storage instructions…" required><%= listing.description || '' %></textarea></label><label>Quantity<input name="quantity" value="<%= listing.quantity || '' %>" placeholder="e.g. 12 meal boxes" required><small>Start with a number so we can estimate meals saved.</small></label></div><div class="form-section"><div class="form-section-title"><span>02</span><div><h2>Where and when?</h2><p>Use a precise collection point and safe food window.</p></div></div><label>Pickup address<textarea name="pickup_address" rows="2" placeholder="Full address and collection instructions" required><%= listing.pickup_address || '' %></textarea></label><div class="map-helper"><button class="button button-secondary" type="button" id="locate-me"><i class="fa-solid fa-location-crosshairs"></i> Use my current location</button><span id="location-status">Coordinates are optional and enable the map.</span></div><input type="hidden" name="latitude" id="latitude" value="<%= listing.latitude || '' %>"><input type="hidden" name="longitude" id="longitude" value="<%= listing.longitude || '' %>"><div class="form-grid"><label>Donation date & time<input type="datetime-local" name="donation_date" value="<%= listing.donation_date ? String(listing.donation_date).replace(' ', 'T').slice(0,16) : '' %>" required></label><label>Expiry date & time<input type="datetime-local" name="expiry_date" value="<%= listing.expiry_date ? String(listing.expiry_date).replace(' ', 'T').slice(0,16) : '' %>" required></label></div></div><div class="form-section"><div class="form-section-title"><span>03</span><div><h2>Add a photo</h2><p>A genuine photo helps volunteers identify your food.</p></div></div><label class="upload-box"><input type="file" name="image" accept="image/jpeg,image/png,image/webp"><span class="upload-preview"><% if(listing.image_url){ %><img src="<%= listing.image_url %>" alt="Current food"><% } else { %><i class="fa-solid fa-cloud-arrow-up"></i><strong>Choose an image</strong><small>JPG, PNG or WebP · maximum 5 MB</small><% } %></span></label></div><div class="form-submit"><a class="button button-secondary" href="/dashboard">Cancel</a><button class="button" type="submit"><%= submitLabel %> <i class="fa-solid fa-arrow-right"></i></button></div></form></section>
<%- include('../partials/footer') %>
