<%- include('../partials/header') %>
<section class="page-hero"><div class="container"><div><span class="kicker">Available now</span><h1>Find food to rescue</h1><p>Search nearby donations and help good food reach the right hands.</p></div></div></section>
<section class="section container listing-layout"><aside class="filter-panel"><div class="mobile-filter-heading"><h2>Filter donations</h2><button type="button" class="filter-close">×</button></div><form method="get" action="/donations"><label>Search<input name="q" value="<%= filters.q || '' %>" placeholder="Food or description"></label><label>Location<input name="location" value="<%= filters.location || '' %>" placeholder="Town or postcode"></label><label>Food category<select name="category"><option value="">All categories</option><% ['Bakery','Cooked Food','Fruit & Vegetables','Dairy','Packaged Food','Other'].forEach(category => { %><option <%= filters.category === category ? 'selected' : '' %>><%= category %></option><% }) %></select></label><label>Expiry<select name="expiry"><option value="">Any time</option><option value="today" <%= filters.expiry === 'today' ? 'selected' : '' %>>Today</option><option value="24hours" <%= filters.expiry === '24hours' ? 'selected' : '' %>>Within 24 hours</option></select></label><label>Sort by<select name="sort"><option value="expiry">Expiring soonest</option><option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Newest first</option></select></label><button class="button full" type="submit"><i class="fa-solid fa-sliders"></i> Apply filters</button><a class="clear-link" href="/donations">Clear all</a></form></aside><div class="listing-results"><div class="results-header"><div><h2><%= listings.length ? 'Food ready for collection' : 'No matching donations' %></h2><p><%= listings.length %> result<%= listings.length === 1 ? '' : 's' %> on this page</p></div><button type="button" class="button button-secondary mobile-filter"><i class="fa-solid fa-sliders"></i> Filters</button></div><% if(listings.length){ %><div class="card-grid two-col"><% listings.forEach(item => { %><%- include('../partials/listing-card', { item }) %><% }) %></div><% if(pages > 1){ %><nav class="pagination" aria-label="Pagination"><% for(let i=1;i<=pages;i++){ const params = new URLSearchParams({...filters,page:i}).toString(); %><a class="<%= i===page ? 'current' : '' %>" href="/donations?<%= params %>"><%= i %></a><% } %></nav><% } %><% } else { %><div class="empty-state"><i class="fa-solid fa-magnifying-glass"></i><h3>Try widening your search</h3><p>Remove a filter or check back soon for new donations.</p><a class="button button-secondary" href="/donations">Reset filters</a></div><% } %></div></section>
<%- include('../partials/footer') %>
