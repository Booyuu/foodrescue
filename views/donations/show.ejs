<%- include('../partials/header') %>
<section class="section container detail-page"><a class="back-link" href="/donations"><i class="fa-solid fa-arrow-left"></i> Back to donations</a><div class="detail-grid"><div><div class="detail-image"><% if(listing.image_url){ %><img src="<%= listing.image_url %>" alt="<%= listing.food_name %>"><% } else { %><div class="image-placeholder"><i class="fa-solid fa-bowl-food"></i></div><% } %><span class="status-badge status-<%= listing.status.toLowerCase() %>"><%= listing.status %></span></div><% if(listing.latitude && listing.longitude){ %><div class="panel map-panel"><div class="panel-heading"><div><h2>Pickup map</h2><p>Exact handover details are shown below.</p></div></div><div id="pickup-map" data-lat="<%= listing.latitude %>" data-lng="<%= listing.longitude %>" data-title="<%= listing.food_name %>"></div></div><link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"><script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script><% } %></div><div class="detail-content"><div class="eyebrow"><%= listing.food_category %></div><h1><%= listing.food_name %></h1><p class="detail-description"><%= listing.description %></p><div class="countdown-box <%= listing.status !== 'Available' ? 'muted' : '' %>"><i class="fa-regular fa-clock"></i><div><small><%= listing.status === 'Available' ? 'Time left to collect' : 'Listing status' %></small><strong <%= listing.status === 'Available' ? `data-expiry="${String(listing.expiry_date).replace(' ', 'T')}"` : '' %>><%= listing.status === 'Available' ? 'Calculating…' : listing.status %></strong></div></div><dl class="detail-list"><div><dt><i class="fa-solid fa-box"></i> Quantity</dt><dd><%= listing.quantity %> · ~<%= listing.meals_estimate %> meals</dd></div><div><dt><i class="fa-solid fa-calendar-day"></i> Donated</dt><dd><%= formatDate(listing.donation_date) %></dd></div><div><dt><i class="fa-solid fa-calendar-xmark"></i> Expires</dt><dd><%= formatDate(listing.expiry_date) %></dd></div><div><dt><i class="fa-solid fa-location-dot"></i> Pickup</dt><dd><%= listing.pickup_address %></dd></div><div><dt><i class="fa-solid fa-user"></i> Donor</dt><dd><%= listing.donor_name %><% if(user && (user.role === 'Volunteer' || user.user_id === listing.donor_id || user.role === 'Admin')){ %><br><a href="tel:<%= listing.donor_mobile %>"><%= listing.donor_mobile %></a> · <a href="mailto:<%= listing.donor_email %>"><%= listing.donor_email %></a><% } %></dd></div></dl><% if(!user){ %><div class="action-box"><p>Log in as a volunteer to accept this collection.</p><a class="button full" href="/login?next=/donations/<%= listing.listing_id %>">Log in to claim</a></div><% } else if(user.role === 'Volunteer' && listing.status === 'Available'){ %><form class="action-box" method="post" action="/volunteer/claim/<%= listing.listing_id %>" data-confirm="Accept responsibility for collecting this food before it expires?"><p><strong>Ready to help?</strong><br>Only accept if you can complete the collection safely.</p><button class="button full" type="submit">Accept collection <i class="fa-solid fa-arrow-right"></i></button></form><% } else if(user.role === 'Volunteer' && listing.volunteer_id === user.user_id){ %><a class="button full" href="/volunteer/claims/<%= listing.listing_id %>">View my collection job</a><% } else if(user.role === 'Donor' && listing.donor_id === user.user_id && listing.status === 'Available'){ %><div class="button-row"><a class="button" href="/donations/<%= listing.listing_id %>/edit">Edit listing</a></div><% } %></div></div></section>
<%- include('../partials/footer') %>
