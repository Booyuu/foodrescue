<%- include('../partials/header') %>
<section class="page-hero compact"><div class="container"><div><span class="kicker">Collection job #<%= claim.claim_id %></span><h1><%= claim.food_name %></h1><p>Keep the donor updated by completing each step in order.</p></div><span class="status-badge large status-<%= claim.status.toLowerCase() %>"><%= claim.status %></span></div></section><section class="section container claim-layout"><div class="panel timeline-panel"><h2>Collection progress</h2><div class="timeline"><div class="timeline-step done"><span><i class="fa-solid fa-check"></i></span><div><strong>Accepted</strong><small><%= formatDate(claim.created_at) %></small></div></div><div class="timeline-line <%= ['Collected','Delivered'].includes(claim.collection_status) ? 'done' : '' %>"></div><div class="timeline-step <%= ['Collected','Delivered'].includes(claim.collection_status) ? 'done' : '' %>"><span><i class="fa-solid fa-box"></i></span><div><strong>Collected</strong><small><%= claim.collection_time ? formatDate(claim.collection_time) : 'Awaiting pickup' %></small></div></div><div class="timeline-line <%= claim.collection_status === 'Delivered' ? 'done' : '' %>"></div><div class="timeline-step <%= claim.collection_status === 'Delivered' ? 'done' : '' %>"><span><i class="fa-solid fa-house-circle-check"></i></span><div><strong>Delivered</strong><small><%= claim.delivery_time ? formatDate(claim.delivery_time) : 'Not delivered yet' %></small></div></div></div><% if(claim.collection_status === 'Accepted'){ %><form method="post" action="/volunteer/claims/<%= claim.listing_id %>/status" data-confirm="Confirm that you have collected the food?"><input type="hidden" name="status" value="Collected"><button class="button full">Mark as collected</button></form><% } else if(claim.collection_status === 'Collected'){ %><form method="post" action="/volunteer/claims/<%= claim.listing_id %>/status" data-confirm="Confirm that this food has been delivered?"><input type="hidden" name="status" value="Delivered"><button class="button full">Mark as delivered</button></form><% } else { %><div class="notice success"><i class="fa-solid fa-circle-check"></i><div><strong>Delivery complete</strong><p>Excellent work—this rescue is ready for donor confirmation.</p></div></div><% } %></div><aside><div class="panel contact-card"><h2>Pickup information</h2><dl class="detail-list"><div><dt>Address</dt><dd><%= claim.pickup_address %></dd></div><div><dt>Donor</dt><dd><%= claim.donor_name %></dd></div><div><dt>Contact</dt><dd><a href="tel:<%= claim.donor_mobile %>"><%= claim.donor_mobile %></a><br><a href="mailto:<%= claim.donor_email %>"><%= claim.donor_email %></a></dd></div><div><dt>Safe until</dt><dd><%= formatDate(claim.expiry_date) %></dd></div></dl></div><div class="panel qr-card"><h2>Handover QR</h2><p>Show this to the donor during collection.</p><img src="<%= qrCode %>" alt="Collection confirmation QR code"><code><%= claim.confirmation_code %></code></div></aside></section>
<%- include('../partials/footer') %>
