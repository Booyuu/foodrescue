<%- include('../partials/header') %>
<section class="page-hero compact"><div class="container"><div><span class="kicker">Administration</span><h1>Manage listings</h1><p>Review and remove expired or inappropriate food posts.</p></div><a class="button button-secondary" href="/admin"><i class="fa-solid fa-arrow-left"></i> Overview</a></div></section><section class="section container"><form class="toolbar" method="get"><label class="search-input"><i class="fa-solid fa-magnifying-glass"></i><input name="q" value="<%= filters.q || '' %>" placeholder="Food or donor"></label><select name="status"><option value="">All statuses</option><% ['Available','Claimed','Collected','Delivered','Completed','Expired'].forEach(status => { %><option <%= filters.status===status?'selected':'' %>><%= status %></option><% }) %></select><button class="button button-small">Filter</button><a href="/admin/listings">Clear</a></form><div class="panel"><div class="table-wrap"><table><thead><tr><th>Food</th><th>Donor</th><th>Status</th><th>Quantity</th><th>Expires</th><th><span class="sr-only">Actions</span></th></tr></thead><tbody><% listings.forEach(item => { %><tr><td><a class="table-food" href="/donations/<%= item.listing_id %>"><% if(item.image_url){ %><img src="<%= item.image_url %>" alt=""><% } else { %><span><i class="fa-solid fa-bowl-food"></i></span><% } %><div><strong><%= item.food_name %></strong><small><%= item.food_category %></small></div></a></td><td><%= item.donor_name %></td><td><span class="status-badge status-<%= item.status.toLowerCase() %>"><%= item.status %></span></td><td><%= item.quantity %></td><td><%= formatDate(item.expiry_date) %></td><td><div class="table-actions"><a class="icon-button" href="/donations/<%= item.listing_id %>"><i class="fa-regular fa-eye"></i></a><form method="post" action="/admin/listings/<%= item.listing_id %>?_method=DELETE" data-confirm="Permanently remove this listing and any associated claim?"><button class="icon-button danger"><i class="fa-regular fa-trash-can"></i></button></form></div></td></tr><% }) %></tbody></table></div></div></section>
<%- include('../partials/footer') %>
