<%- include('../partials/header') %>
<section class="page-hero compact"><div class="container"><div><span class="kicker">Administration</span><h1>Manage users</h1><p>Verify donors and control platform access.</p></div><a class="button button-secondary" href="/admin"><i class="fa-solid fa-arrow-left"></i> Overview</a></div></section><section class="section container"><form class="toolbar" method="get"><label class="search-input"><i class="fa-solid fa-magnifying-glass"></i><input name="q" value="<%= filters.q || '' %>" placeholder="Search name or email"></label><select name="role"><option value="">All roles</option><% ['Donor','Volunteer','Admin'].forEach(role => { %><option <%= filters.role===role?'selected':'' %>><%= role %></option><% }) %></select><button class="button button-small">Filter</button><a href="/admin/users">Clear</a></form><div class="panel"><div class="table-wrap"><table><thead><tr><th>User</th><th>Contact</th><th>Role</th><th>Verification</th><th>Access</th><th>Joined</th><th><span class="sr-only">Actions</span></th></tr></thead><tbody><% users.forEach(member => { %><tr><td><strong><%= member.name %></strong></td><td><%= member.email %><br><small><%= member.mobile_number %></small></td><td><span class="role-badge"><%= member.role %></span></td><td><% if(member.role==='Donor'){ %><%= member.is_verified ? 'Verified' : 'Pending' %><% } else { %>—<% } %></td><td><span class="status-dot <%= member.is_active ? 'online' : '' %>"></span><%= member.is_active ? 'Active' : 'Disabled' %></td><td><%= formatDate(member.created_at, false) %></td><td><div class="table-actions"><% if(member.role==='Donor' && !member.is_verified){ %><form method="post" action="/admin/users/<%= member.user_id %>/verify"><button class="button button-tiny">Verify</button></form><% } %><% if(member.user_id !== user.user_id){ %><form method="post" action="/admin/users/<%= member.user_id %>/toggle" data-confirm="<%= member.is_active ? 'Disable this user account?' : 'Restore this user account?' %>"><button class="icon-button <%= member.is_active ? 'danger' : '' %>" aria-label="Toggle access"><i class="fa-solid fa-<%= member.is_active ? 'user-slash' : 'user-check' %>"></i></button></form><% } %></div></td></tr><% }) %></tbody></table></div></div></section>
<%- include('../partials/footer') %>
