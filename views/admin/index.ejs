<%- include('../partials/header') %>
<section class="page-hero compact admin-hero"><div class="container"><div><span class="kicker">Administration</span><h1>Community impact overview</h1><p>Live operational and sustainability indicators.</p></div><div class="button-row"><a class="button button-secondary" href="/admin/users">Manage users</a><a class="button" href="/admin/listings">Moderate listings</a></div></div></section><section class="section container dashboard-section"><% if(stats.pending_donors){ %><a class="notice warning" href="/admin/users?role=Donor"><i class="fa-solid fa-user-clock"></i><div><strong><%= stats.pending_donors %> donor account<%= stats.pending_donors==1?'':'s' %> awaiting verification</strong><p>Review them to unlock food listing access.</p></div><i class="fa-solid fa-arrow-right"></i></a><% } %><div class="widget-grid"><div class="widget"><span class="widget-icon green"><i class="fa-solid fa-bowl-food"></i></span><div><small>Meals rescued</small><strong><%= Number(stats.meals_saved).toLocaleString() %></strong></div></div><div class="widget"><span class="widget-icon amber"><i class="fa-solid fa-box-open"></i></span><div><small>Active listings</small><strong><%= stats.active_listings %></strong></div></div><div class="widget"><span class="widget-icon blue"><i class="fa-solid fa-person-biking"></i></span><div><small>Active volunteers</small><strong><%= stats.active_volunteers %></strong></div></div><div class="widget"><span class="widget-icon coral"><i class="fa-solid fa-cloud"></i></span><div><small>CO₂ avoided</small><strong><%= Number(stats.co2_saved).toFixed(1) %> kg</strong></div></div></div><div class="admin-grid"><div class="panel chart-panel"><div class="panel-heading"><div><h2>Rescue activity</h2><p>Donations and meals saved over six months.</p></div></div><canvas id="impact-chart" data-chart='<%- JSON.stringify(chart) %>'></canvas></div><div class="panel mini-impact"><h2>This period</h2><div><span>Last 7 days</span><strong><%= stats.saved_week %> meals</strong></div><div><span>Last 30 days</span><strong><%= stats.saved_month %> meals</strong></div><div><span>Completed</span><strong><%= stats.completed_collections %> collections</strong></div><div><span>All donations</span><strong><%= stats.total_donations %> listings</strong></div></div></div><div class="admin-grid"><div class="panel"><div class="panel-heading"><div><h2>Recent donations</h2><p>Latest listings across the platform.</p></div><a href="/admin/listings">View all</a></div><div class="simple-list"><% recent.forEach(item => { %><a href="/donations/<%= item.listing_id %>"><span class="list-icon"><i class="fa-solid fa-bowl-food"></i></span><div><strong><%= item.food_name %></strong><small><%= item.donor_name %> · <%= formatDate(item.created_at) %></small></div><span class="status-badge status-<%= item.status.toLowerCase() %>"><%= item.status %></span></a><% }) %></div></div><div class="panel"><h2>Volunteer leaderboard</h2><p>Completed deliveries that keep our community moving.</p><ol class="leaderboard"><% leaderboard.forEach((volunteer,index) => { %><li><span><%= index+1 %></span><div><strong><%= volunteer.name %></strong><small><%= volunteer.meals %> meals rescued</small></div><b><%= volunteer.collections %></b></li><% }) %></ol></div></div></section><script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"></script>
<%- include('../partials/footer') %>
